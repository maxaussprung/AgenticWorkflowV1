# It loads variables into the Node.js environment automatically allowing you to
# use them in Next.js data fetching methods and API routes.
# Using the 'NEXT_PUBLIC_' prefix, it allows you to use it anywhere in your code.
#NEXT_PUBLIC_ENABLE_MOCK_SERVER=false
# Local Docker stack is a development environment: activate dev-only behaviour,
# e.g. disabling the Startseite-redirect guard (useRedirectRoute) so the type-tile
# page (/directive-orders) and create masks are reachable without scanning an ID.
NEXT_PUBLIC_ENV=development

IMG_SRC=https://*.post.at
SCRIPT_SRC=https://*.azureedge.net
STYLE_SRC=https://*.azureedge.net
FRAME_SRC=https://kiamabn.b2clogin.com
CONNECT_SRC=localhost:* https://*.post.at https://*.applicationinsights.azure.com https://kiamabn.b2clogin.com https://*.openstreetmap.org
NEXT_PUBLIC_API_BASE_URL=https://localhost:5001

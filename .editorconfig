# EditorConfig — repo-wide formatting baseline. https://editorconfig.org
# Enforced in CI via `dotnet format` (C#) and ESLint/Prettier (frontend).
root = true

[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true
indent_style = space
indent_size = 4

[*.{cs,csx}]
indent_size = 4
# Prefer file-scoped namespaces and var where the type is apparent (C# defaults).
csharp_style_namespace_declarations = file_scoped:suggestion
dotnet_sort_system_directives_first = true

[*.{ts,tsx,js,jsx,json,jsonc,css,scss,yml,yaml}]
indent_size = 2

[*.{md,mdx}]
indent_size = 2
trim_trailing_whitespace = false  # trailing spaces are meaningful (hard line breaks)

[*.py]
indent_size = 4

[*.{csproj,props,targets,xml,config}]
indent_size = 2

[Makefile]
indent_style = tab
